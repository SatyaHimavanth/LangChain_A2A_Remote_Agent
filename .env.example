# Calculator agent server
CALCULATOR_AGENT_HOST=127.0.0.1
CALCULATOR_AGENT_PORT=9999

# Static bearer tokens for authenticated/extended calculator tools.
# Comma-separate multiple tokens. The README examples use local-dev-token.
VALID_API_TOKENS=local-dev-token
# CALCULATOR_AGENT_API_TOKENS=local-dev-token
# VALID_API_TOKEN=local-dev-token

# Model provider selected by agents/CalculatorAgent/llm_models.py.
# Common values: azure_openai, openai, google_genai, ollama
MODEL_SOURCE=azure_openai
CHAT_MODEL_NAME=

# Azure OpenAI
CHAT_DEPLOYMENT_NAME=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2024-12-01-preview

# OpenAI
# MODEL_SOURCE=openai
# OPENAI_API_KEY=
# CHAT_MODEL_NAME=gpt-4.1-mini

# Google GenAI
# MODEL_SOURCE=google_genai
# GOOGLE_API_KEY=
# CHAT_MODEL_NAME=gemini-2.5-flash

# Ollama
# MODEL_SOURCE=ollama
# CHAT_MODEL_NAME=llama3.1

# Optional OAuth introspection validator settings if you switch validators in
# agents/CalculatorAgent/__main__.py.
# OAUTH_INTROSPECT_URL=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
